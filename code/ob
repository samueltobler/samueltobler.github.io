<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Body Type Counter</title>
  <style>
    :root {
      --bg: #f6f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --border: #e5e7eb;
      --under: #3b82f6;
      --normal: #10b981;
      --obese: #ef4444;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width: 480px;
      margin: 0 auto;
      padding: 16px;
      min-height: 100vh;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 16px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
    }

    h1 {
      margin: 0 0 6px;
      font-size: 1.4rem;
      text-align: center;
    }

    .sub {
      margin: 0 0 18px;
      text-align: center;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .buttons {
      display: grid;
      gap: 12px;
      margin-bottom: 18px;
    }

    button {
      border: none;
      border-radius: 14px;
      padding: 16px;
      font-size: 1rem;
      font-weight: 700;
      color: white;
      cursor: pointer;
      transition: transform 0.08s ease, opacity 0.2s ease;
    }

    button:active {
      transform: scale(0.98);
    }

    .under { background: var(--under); }
    .normal { background: var(--normal); }
    .obese { background: var(--obese); }
    .reset {
      background: #111827;
      margin-top: 8px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 18px;
    }

    .stat {
      background: #f9fafb;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 8px;
      text-align: center;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .stat-value {
      font-size: 1.4rem;
      font-weight: 700;
    }

    .chart-box {
      background: #f9fafb;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
    }

    canvas {
      width: 100%;
      height: 260px;
      display: block;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>Body Type Counter</h1>
      <p class="sub">Tap a button to count and update the graph instantly</p>

      <div class="buttons">
        <button class="under" onclick="addCount('underweight')">Underweight</button>
        <button class="normal" onclick="addCount('normal')">Normal</button>
        <button class="obese" onclick="addCount('obese')">Obese</button>
      </div>

      <div class="stats">
        <div class="stat">
          <div class="stat-label">Underweight</div>
          <div class="stat-value" id="underweightCount">0</div>
        </div>
        <div class="stat">
          <div class="stat-label">Normal</div>
          <div class="stat-value" id="normalCount">0</div>
        </div>
        <div class="stat">
          <div class="stat-label">Obese</div>
          <div class="stat-value" id="obeseCount">0</div>
        </div>
      </div>

      <div class="chart-box">
        <canvas id="chart" width="400" height="260"></canvas>
      </div>

      <button class="reset" onclick="resetCounts()">Reset</button>
    </div>
  </div>

  <script>
    const data = JSON.parse(localStorage.getItem("bodyTypeData")) || {
      underweight: 0,
      normal: 0,
      obese: 0
    };

    function saveData() {
      localStorage.setItem("bodyTypeData", JSON.stringify(data));
    }

    function addCount(type) {
      data[type]++;
      saveData();
      updateUI();
      drawChart();
    }

    function resetCounts() {
      data.underweight = 0;
      data.normal = 0;
      data.obese = 0;
      saveData();
      updateUI();
      drawChart();
    }

    function updateUI() {
      document.getElementById("underweightCount").textContent = data.underweight;
      document.getElementById("normalCount").textContent = data.normal;
      document.getElementById("obeseCount").textContent = data.obese;
    }

    function drawChart() {
      const canvas = document.getElementById("chart");
      const ctx = canvas.getContext("2d");
      const width = canvas.width;
      const height = canvas.height;

      ctx.clearRect(0, 0, width, height);

      const values = [data.underweight, data.normal, data.obese];
      const labels = ["Under", "Normal", "Obese"];
      const colours = ["#3b82f6", "#10b981", "#ef4444"];
      const maxValue = Math.max(...values, 1);

      const padding = 35;
      const chartHeight = height - 70;
      const chartWidth = width - padding * 2;
      const barWidth = 70;
      const gap = (chartWidth - barWidth * 3) / 2;

      ctx.strokeStyle = "#d1d5db";
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(padding, height - padding);
      ctx.lineTo(width - padding, height - padding);
      ctx.stroke();

      values.forEach((value, i) => {
        const x = padding + i * (barWidth + gap);
        const barHeight = (value / maxValue) * (chartHeight - 20);
        const y = height - padding - barHeight;

        ctx.fillStyle = colours[i];
        roundRect(ctx, x, y, barWidth, barHeight, 10);
        ctx.fill();

        ctx.fillStyle = "#111827";
        ctx.font = "bold 16px Arial";
        ctx.textAlign = "center";
        ctx.fillText(value, x + barWidth / 2, y - 8);

        ctx.fillStyle = "#6b7280";
        ctx.font = "14px Arial";
        ctx.fillText(labels[i], x + barWidth / 2, height - 12);
      });
    }

    function roundRect(ctx, x, y, width, height, radius) {
      ctx.beginPath();
      ctx.moveTo(x + radius, y);
      ctx.lineTo(x + width - radius, y);
      ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
      ctx.lineTo(x + width, y + height);
      ctx.lineTo(x, y + height);
      ctx.lineTo(x, y + radius);
      ctx.quadraticCurveTo(x, y, x + radius, y);
      ctx.closePath();
    }

    updateUI();
    drawChart();
  </script>
</body>
</html>